# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# API-Football (api-sports.io) — get key from https://dashboard.api-football.com
FOOTBALL_API_KEY=your-api-football-key

# YouTube Data API v3 — get key from https://console.cloud.google.com
YOUTUBE_API_KEY=your-youtube-api-key

# Cron secret (protects cron endpoints from unauthorized access)
CRON_SECRET=your-random-secret-string
